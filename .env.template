# GardRail Environment Configuration Template
# Copy this to .env and fill in with your values

# ============================================================================
# LLM Provider Configuration (REQUIRED - choose one)
# ============================================================================

# OpenAI
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: for Azure OpenAI

# Google Gemini (alternative)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_MODEL=gemini-pro  # Optional

# Anthropic Claude (alternative)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Local Ollama (alternative)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# ============================================================================
# Server Configuration (OPTIONAL)
# ============================================================================

GUARDRAIL_HOST=127.0.0.1
GUARDRAIL_PORT=8000
LOG_LEVEL=INFO  # INFO, DEBUG, WARNING, ERROR

# ============================================================================
# Authentication (OPTIONAL)
# ============================================================================

# API Key for protected endpoints (comma-separated for multiple keys)
ADMIN_API_KEYS=your-admin-key-1,your-admin-key-2

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Database Configuration (OPTIONAL)
# ============================================================================

DATABASE_URL=sqlite:///guardrail.db
DATABASE_POOL_SIZE=5  # Number of SQLite connection pool connections

# ============================================================================
# Security Configuration (OPTIONAL)
# ============================================================================

DRIFT_THRESHOLD=0.75  # Similarity threshold for drift detection (0.0-1.0)
ENABLE_PII_ANONYMIZATION=true  # Redact PII before agent processing
RATE_LIMIT_REQUESTS=200  # Requests per time window
RATE_LIMIT_WINDOW_SECONDS=60
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# ============================================================================
# Multi-Tenancy (OPTIONAL)
# ============================================================================

DEFAULT_TENANT_ID=default  # Default tenant for requests without X-Tenant-Id header

# ============================================================================
# Feature Flags (OPTIONAL)
# ============================================================================

ENABLE_RULE_EVOLUTION=true  # AI-powered rule learning from attacks
ENABLE_BEHAVIORAL_DRIFT=true  # Intent fingerprinting and drift detection
ENABLE_AUTO_BLOCK_TIMEOUT=true  # Auto-block threats after timeout

# ============================================================================
# GitHub Integration (OPTIONAL - for rule evolution)
# ============================================================================

# GITHUB_TOKEN=ghp_your-github-token-here
# GITHUB_REPO=sriman676/GardRail

# ============================================================================
# External Notifications (OPTIONAL)
# ============================================================================

# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# WEBHOOK_VERIFY_SSL=true

# ============================================================================
# Monitoring & Logging (OPTIONAL)
# ============================================================================

METRICS_ENABLED=true  # Enable Prometheus metrics at /metrics
STRUCTURED_LOGGING_ENABLED=true  # JSON formatted logs
